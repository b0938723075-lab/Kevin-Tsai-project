# 1. AI 引擎設定 (二選一，建議先用 OpenAI)
OPENAI_API_KEY="你的_OpenAI_API_Key_請填在這裡"
GEMINI_API_KEY="你的_Gemini_API_Key_請填在這裡"

# 2. 通知服務設定
LINE_NOTIFY_TOKEN="你的_LINE_Notify_權杖_請填在這裡"
TELEGRAM_BOT_TOKEN="你的_Telegram_機器人_Token_請填在這裡"
TELEGRAM_CHAT_ID="你要發送通知的_Chat_ID_請填在這裡"

# 3. 搜尋服務設定 (Tavily AI & Apify)
